  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5c6370", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": { "foreground": "#98c379" }
    },
    {
      "name": "Escape sequence",
      "scope": ["constant.character.escape", "constant.other.placeholder"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#d19a66" }
    },
    {
      "name": "Language constant",
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#d19a66" }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#e5c07b" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "keyword.other"],
      "settings": { "foreground": "#61afef" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#5c9aa8" }
    },
    {
      "name": "Storage / declaration keyword",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Built-in type",
      "scope": ["support.type", "support.type.primitive"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Type name",
      "scope": ["entity.name.type", "entity.name.class", "entity.name.struct", "entity.name.enum"],
      "settings": { "foreground": "#5fc0c8" }
    },
    {
      "name": "Namespace / module",
      "scope": ["entity.name.namespace", "entity.name.module", "entity.name.section"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#dba45e" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#c6a98a" }
    },
    {
      "name": "Property",
      "scope": ["variable.other.property", "support.type.property-name", "meta.object-literal.key"],
      "settings": { "foreground": "#9fc3c9" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#e06c75" }
    },
    {
      "name": "Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#d19a66" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#8a929e" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#e06c75" }
    },
    {
      "name": "Markup heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#56b6c2", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#dba45e", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markup link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#98c379" }
    }
  ],
  "semanticTokenColors": {
    "keyword": "#61afef",
    "function": "#dba45e",
    "method": "#dba45e",
    "macro": "#dba45e",
    "type": "#56b6c2",
    "class": "#5fc0c8",
    "struct": "#5fc0c8",
    "interface": "#5fc0c8",
    "enum": "#5fc0c8",
    "enumMember": "#d19a66",
    "typeParameter": "#9fc3c9",
    "namespace": "#56b6c2",
    "variable": "#abb2bf",
    "variable.readonly": "#e5c07b",
    "parameter": "#c6a98a",
    "property": "#9fc3c9",
    "string": "#98c379",
    "number": "#d19a66",
    "comment": "#5c6370",
    "operator": "#5c9aa8"
  }
}
