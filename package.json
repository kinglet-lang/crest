{
  "name": "crest",
  "displayName": "Crest",
  "description": "A dark color theme for VS Code, drawn from the Kinglet palette — teal and cream with warm amber accents.",
  "version": "0.1.0",
  "publisher": "kinglet-lang",
  "author": "Kinglet Language Developers",
  "license": "MIT",
  "icon": "image/icon.png",
  "galleryBanner": {
    "color": "#012E46",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kinglet-lang/crest"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "dark",
    "kinglet",
    "teal"
  ],
  "scripts": {
    "export-icons": "bash scripts/export-icons.sh",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2"
  },
  "contributes": {
    "themes": [
      {
        "label": "Crest",
        "uiTheme": "vs-dark",
        "path": "./themes/crest-color-theme.json"
      }
    ]
  }
}
